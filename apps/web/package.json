{
  "name": "@urlshort/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "URL shortener Web (React + Vite)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
