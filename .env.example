# ---- Database (Postgres via docker-compose) ----
POSTGRES_USER=urlshort
POSTGRES_PASSWORD=urlshort
POSTGRES_DB=urlshort
POSTGRES_PORT=5432

# DATABASE_URL used by the API to connect to Postgres
DATABASE_URL=postgres://urlshort:urlshort@localhost:5432/urlshort

# ---- API (NestJS) ----
API_PORT=3000
NODE_ENV=development

# Public base URL used to build short links (e.g. http://localhost:3000/abc123)
PUBLIC_BASE_URL=http://localhost:3000

# ---- Web (Vite) ----
VITE_API_URL=http://localhost:3000
